{
  "name": "coursetable-root",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "workspaces": [
    "api",
    "frontend"
  ],
  "scripts": {
    "checks": "bun run depcheck && bun run format:check && bun run lint:check && bun run lint:css:check && bun run resize-image:check && bun run typecheck && bun run test:snapshot && bun run test:worker && bun run validate:worker-catalog && bun run --cwd api test && bun run --cwd frontend test",
    "checks:fix": "bun run format && bun run lint && bun run lint:css && bun run resize-image",
    "typecheck": "tsc && tsc -p frontend && tsc -p api && tsc -p worker",
    "depcheck": "bunx depcheck . --ignore-patterns=api,frontend && bunx depcheck api && bunx depcheck frontend",
    "format": "prettier --write .",
    "format:check": "prettier -l .",
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "lint:css": "stylelint --fix \"**/*.css\"",
    "lint:css:check": "stylelint \"**/*.css\"",
    "local:https:setup": "sh tools/local-https/setup.sh",
    "prepare": "husky || true",
    "resize-image": "bun tools/resize-image.mts",
    "resize-image:check": "bun tools/resize-image.mts --test",
    "snapshot:publish": "bun tools/catalog-snapshot/generate-published-snapshot.mts --config config/catalog-snapshot.ucsd.yaml",
    "snapshot:tss": "bun tools/catalog-snapshot/generate-tss-published-snapshot.mts",
    "snapshot:tss:capture": "bun tools/catalog-snapshot/capture-tss-schedule.mts",
    "snapshot:tracer": "bun tools/catalog-snapshot/generate-tracer-snapshot.mts --config config/catalog-snapshot.ucsd.yaml",
    "snapshot:schedule": "bun tools/catalog-snapshot/generate-schedule-snapshot.mts --config config/catalog-snapshot.ucsd.yaml",
    "test:snapshot": "vitest run tools/**/*.test.ts",
    "test:worker": "vitest run worker",
    "build:worker": "bun run --cwd frontend build && wrangler deploy --dry-run --config worker/wrangler.jsonc",
    "validate:worker-catalog": "VITE_API_ENDPOINT= bun run --cwd frontend build && bun worker/scripts/validateCatalogWorker.mts",
    "validate:failure-safety": "bun worker/scripts/validateFailureSafety.mts",
    "validate:staging-deployment": "bun tools/staging-deployment/validateStagingDeployment.mts",
    "validate:production-deployment": "bun tools/staging-deployment/validateProductionDeployment.mts",
    "validate:real-backend-auth": "API_PORT=3010 bun tools/real-backend-auth-validation/validateRealBackendAuth.mts",
    "validate:core-backend": "API_PORT=3010 bun tools/real-backend-auth-validation/validateRealBackendAuth.mts",
    "validate:local-platform": "bun tools/local-platform/validateLocalPlatform.mts",
    "course-data:migrate": "bun tools/course-data-store/migrateCourseDataStore.mts",
    "course-data:import": "bun tools/course-data-store/importSnapshot.mts",
    "validate:course-data-tracer": "bun tools/course-data-store/validateCourseDataTracer.mts"
  },
  "trustedDependencies": [
    "api",
    "frontend",
    "sharp"
  ],
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@cloudflare/workers-types": "4.20260424.1",
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/import-types-preset": "^3.0.0",
    "@graphql-codegen/introspection": "^4.0.3",
    "@graphql-codegen/near-operation-file-preset": "^3.0.0",
    "@graphql-codegen/typescript": "^4.1.2",
    "@graphql-codegen/typescript-graphql-request": "^6.2.0",
    "@graphql-codegen/typescript-operations": "^4.4.0",
    "@graphql-codegen/typescript-react-apollo": "^4.3.2",
    "@types/image-size": "^0.8.0",
    "@types/sharp": "^0.32.0",
    "commander": "^13.0.0",
    "eslint": "^10.2.0",
    "eslint-config-jc": "^7.1.0",
    "eslint-plugin-css-modules": "^2.12.0",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "husky": "^9.1.7",
    "image-size": "^1.2.0",
    "jsonc-parser": "^3.3.1",
    "lint-staged": "^15.3.0",
    "playwright": "^1.61.1",
    "prettier": "^3.4.2",
    "sharp": "^0.33.5",
    "stylelint": "^16.12.0",
    "stylelint-config-standard": "^36.0.1",
    "tsconfig-jc": "^2.3.1",
    "typescript": "~6.0.3",
    "typescript-plugin-css-modules": "^5.1.0",
    "vitest": "4.1.4",
    "wrangler": "4.85.0",
    "yaml": "^2.9.0",
    "zod": "^3.24.1"
  },
  "engines": {
    "npm": "please-use-bun",
    "yarn": "please-use-bun",
    "pnpm": "please-use-bun"
  },
  "overrides": {
    "eslint-plugin-react-hooks": "7.0.0",
    "uuid": "11.1.1"
  },
  "patchedDependencies": {
    "eslint-plugin-css-modules@2.12.0": "patches/eslint-plugin-css-modules@2.12.0.patch"
  },
  "dependencies": {
    "@upstash/redis": "^1.38.0",
    "drizzle-orm": "0.45.2",
    "postgres": "^3.4.5"
  }
}
