# Local-only defaults for Beta-1 real backend auth validation.
# These values are intentionally non-secret and are safe for disposable Docker
# Compose validation runs. Copy this file and override values if local ports or
# container names conflict.

API_PORT=3000
API_NETWORK=coursetable_auth_validation_api
EXPRESS_HOST=coursetable-auth-api

DB_HOST=coursetable-auth-db
DB_PORT=5432
DB_NAME=coursetable_data
DB_USER=postgres
DB_ROOT_PASSWORD=coursetable-local-postgres-password

FERRY_DB_NAME=postgres
FERRY_DB_USER=ferry
FERRY_DB_PASSWORD=coursetable-local-ferry-password

HASURA_DB_USER=hasura
HASURA_DB_PASSWORD=coursetable-local-hasura-db-password
HASURA_GRAPHQL_ADMIN_SECRET=coursetable-local-hasura-secret
GRAPHQL_ENGINE_HOST=coursetable-auth-graphql

REDIS_HOST=coursetable-auth-redis

PGADMIN_HOST=coursetable-auth-pgadmin
PGADMIN_EMAIL=admin@coursetable.dev
PGADMIN_PASSWORD=coursetable-local-pgadmin-password

CANNY_KEY=coursetable-local-canny-key
CHALLENGE_PASSWORD=coursetable-local-challenge-password
FERRY_RELOAD_SECRET=coursetable-local-ferry-reload-secret
FRONTEND_ENDPOINT=http://localhost:3001
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SESSION_SECRET=coursetable-local-session-secret-change-only-for-local-debug
YALIES_API_KEY=coursetable-local-yalies-api-key

OVERWRITE_CATALOG=false
HOT_RELOAD=false
BUN_DEBUG_HOST_PORT=6499
HASURA_HOST_PORT=8085
POSTGRES_HOST_PORT=5432
PGADMIN_HOST_PORT=8081
