{
  "name": "api",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "prestart": "bun run codegen",
    "start": "bun run codegen:format && tsx watch src/server.ts",
    "start:prod": "tsx src/server.ts",
    "test": "vitest run",
    "db:generate": "DB_URL=postgresql://migration-generation.invalid/app drizzle-kit generate:pg",
    "db:migrate": "tsx drizzle/migrate.ts",
    "db:migrate:hosted": "tsx drizzle/migrate.hosted.ts",
    "app-db:backup:prepare-role": "tsx src/appDatabaseBackup/backupRole.command.ts",
    "app-db:backup": "tsx src/appDatabaseBackup/backup.command.ts",
    "app-db:restore:verify": "tsx src/appDatabaseBackup/restore.command.ts",
    "app-db:recovery:test": "tsx src/appDatabaseBackup/localRecovery.command.ts",
    "email-delivery-audit:lookup": "tsx src/auth/emailDeliveryAudit.lookup.ts",
    "db:push": "drizzle-kit push:pg",
    "db:seed:friends": "tsx drizzle/seed-friends.ts",
    "test:db:migrate": "vitest run drizzle/migrate.command.test.ts",
    "codegen": "graphql-codegen --config graphql-codegen.ts && tsx ../tools/fix-gql-generated-code.mts",
    "codegen:format": "prettier -w src/**/*.queries.ts src/graphql-types.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@coursetable/passport-cas": "^0.1.4",
    "@sentry/node": "^8.48.0",
    "chroma-js": "^3.1.2",
    "connect-redis": "^7.1.1",
    "cors": "^2.8.5",
    "csv-writer": "^1.6.0",
    "drizzle-orm": "^0.30.10",
    "express": "^4.21.2",
    "express-async-handler": "^1.2.0",
    "express-session": "^1.18.1",
    "graphql": "^16.10.0",
    "graphql-request": "^7.1.2",
    "graphql-tag": "^2.12.6",
    "http-proxy-middleware": "^3.0.3",
    "jsonwebtoken": "^9.0.2",
    "lz-string": "^1.5.0",
    "morgan": "^1.10.0",
    "passport": "0.6.0",
    "postgres": "^3.4.5",
    "proxy-addr": "^2.0.7",
    "redis": "^4.7.0",
    "resend": "^6.17.2",
    "sitemap": "^8.0.0",
    "tsx": "^4.19.2",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.5",
    "@types/bun": "^1.1.16",
    "@types/chroma-js": "^3.1.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.1",
    "@types/http-proxy-middleware": "^1.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.5",
    "@types/passport": "^1.0.17",
    "@types/proxy-addr": "^2.0.3",
    "drizzle-kit": "^0.20.18",
    "vitest": "4.1.4"
  }
}
