{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "sungrid-staging",
  "main": "src/appWorker.ts",
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "staging.sungridplanner.com",
      "custom_domain": true,
    },
  ],
  "triggers": { "crons": ["0 8 * * *"] },
  "assets": {
    "directory": "../frontend/build",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api", "/api/*", "/ferry", "/ferry/*"],
  },
  "r2_buckets": [
    {
      "binding": "CATALOG_BUCKET",
      "bucket_name": "sungrid-staging-catalog",
    },
  ],
  "hyperdrive": [
    {
      "binding": "APP_DB_HYPERDRIVE_NO_CACHE",
      "id": "00000000000000000000000000000000",
    },
  ],
  "version_metadata": {
    "binding": "CF_VERSION_METADATA",
  },
  "vars": {
    "PUBLIC_LOGIN_ENABLED": "true",
    "CLOUDFLARE_PLAN_IDENTITY": "Workers Free",
    "WORKERS_FREE_REQUESTS_PER_DAY": "100000",
    "WORKERS_FREE_CPU_MS_PER_INVOCATION": "10",
    "WORKERS_FREE_EXTERNAL_SUBREQUESTS_PER_INVOCATION": "50",
    "WORKERS_FREE_CRON_TRIGGERS_PER_ACCOUNT": "5",
    "WORKERS_FREE_STATIC_ASSETS_PER_VERSION": "20000",
    "VERIFICATION_REQUEST_COOLDOWN_SECONDS": "60",
    "VERIFICATION_SOURCE_LIMIT": "5",
    "VERIFICATION_SOURCE_WINDOW_SECONDS": "900",
    "VERIFICATION_GLOBAL_LIMIT": "100",
    "VERIFICATION_GLOBAL_WINDOW_SECONDS": "900",
    "VERIFICATION_ATTEMPT_SOURCE_LIMIT": "20",
    "VERIFICATION_ATTEMPT_SOURCE_WINDOW_SECONDS": "900",
    "VERIFICATION_ATTEMPT_EMAIL_LIMIT": "5",
    "VERIFICATION_ATTEMPT_EMAIL_WINDOW_SECONDS": "900",
    "APPLICATION_SAFETY_SEND_LIMIT": "1000",
    "APPLICATION_SAFETY_SEND_WINDOW_SECONDS": "2592000",
    "APPLICATION_SAFETY_ACCOUNT_WRITE_LIMIT": "50000",
    "APPLICATION_SAFETY_ACCOUNT_WRITE_WINDOW_SECONDS": "2592000",
    "USAGE_ALLOWANCE_WORKER_REQUESTS": "3100000",
    "USAGE_ALLOWANCE_R2_READS": "10000000",
    "USAGE_ALLOWANCE_NEON_ACCOUNT_REQUESTS": "200000",
    "USAGE_ALLOWANCE_UPSTASH_COMMANDS": "500000",
    "USAGE_ALLOWANCE_RESEND_SENDS": "3000",
  },
}
