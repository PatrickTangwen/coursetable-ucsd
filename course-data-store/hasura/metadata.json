{
  "version": 3,
  "sources": [
    {
      "name": "course_data_store",
      "kind": "postgres",
      "configuration": {
        "connection_info": {
          "database_url": {
            "from_env": "COURSE_DATA_STORE_DATABASE_URL"
          },
          "isolation_level": "read-committed",
          "use_prepared_statements": true
        }
      },
      "tables": [
        {
          "table": { "schema": "public", "name": "supported_terms" },
          "configuration": {
            "custom_root_fields": {
              "select": "supportedTerms",
              "select_by_pk": "supportedTerm"
            },
            "custom_column_names": {
              "term_code": "termCode",
              "term_label": "termLabel",
              "date_start": "dateStart",
              "date_end": "dateEnd",
              "snapshot_generated_at": "snapshotGeneratedAt",
              "artifact_fingerprint": "artifactFingerprint"
            }
          },
          "array_relationships": [
            {
              "name": "courses",
              "using": {
                "foreign_key_constraint_on": {
                  "column": "term_code",
                  "table": { "schema": "public", "name": "courses" }
                }
              }
            }
          ],
          "select_permissions": [
            {
              "role": "anonymous",
              "permission": {
                "columns": [
                  "term_code",
                  "term_label",
                  "date_start",
                  "date_end",
                  "snapshot_generated_at"
                ],
                "filter": {},
                "limit": 100
              }
            }
          ]
        },
        {
          "table": { "schema": "public", "name": "courses" },
          "configuration": {
            "custom_root_fields": {
              "select": "courses",
              "select_by_pk": "course"
            },
            "custom_column_names": {
              "term_code": "termCode",
              "course_id": "courseId",
              "course_number": "courseNumber",
              "prerequisites_text": "prerequisitesText",
              "restrictions_text": "restrictionsText",
              "catalog_url": "catalogUrl"
            }
          },
          "object_relationships": [
            {
              "name": "supportedTerm",
              "using": { "foreign_key_constraint_on": "term_code" }
            }
          ],
          "array_relationships": [
            {
              "name": "sections",
              "using": {
                "manual_configuration": {
                  "remote_table": { "schema": "public", "name": "sections" },
                  "column_mapping": {
                    "term_code": "term_code",
                    "course_id": "course_id"
                  },
                  "insertion_order": null
                }
              }
            }
          ],
          "select_permissions": [
            {
              "role": "anonymous",
              "permission": {
                "columns": [
                  "term_code",
                  "course_id",
                  "subject",
                  "course_number",
                  "title",
                  "units",
                  "description",
                  "prerequisites_text",
                  "restrictions_text",
                  "catalog_url"
                ],
                "filter": {},
                "limit": 500
              }
            }
          ]
        },
        {
          "table": { "schema": "public", "name": "sections" },
          "configuration": {
            "custom_root_fields": {
              "select": "sections",
              "select_by_pk": "section"
            },
            "custom_column_names": {
              "term_code": "termCode",
              "section_id": "sectionId",
              "course_id": "courseId",
              "section_code": "sectionCode",
              "meeting_type": "meetingType"
            }
          },
          "object_relationships": [
            {
              "name": "course",
              "using": {
                "manual_configuration": {
                  "remote_table": { "schema": "public", "name": "courses" },
                  "column_mapping": {
                    "term_code": "term_code",
                    "course_id": "course_id"
                  },
                  "insertion_order": null
                }
              }
            }
          ],
          "array_relationships": [
            {
              "name": "meetings",
              "using": {
                "manual_configuration": {
                  "remote_table": { "schema": "public", "name": "meetings" },
                  "column_mapping": {
                    "term_code": "term_code",
                    "section_id": "section_id"
                  },
                  "insertion_order": null
                }
              }
            },
            {
              "name": "instructorLinks",
              "using": {
                "manual_configuration": {
                  "remote_table": {
                    "schema": "public",
                    "name": "section_instructors"
                  },
                  "column_mapping": {
                    "term_code": "term_code",
                    "section_id": "section_id"
                  },
                  "insertion_order": null
                }
              }
            }
          ],
          "select_permissions": [
            {
              "role": "anonymous",
              "permission": {
                "columns": [
                  "term_code",
                  "section_id",
                  "course_id",
                  "section_code",
                  "meeting_type"
                ],
                "filter": {},
                "limit": 1000
              }
            }
          ]
        },
        {
          "table": { "schema": "public", "name": "meetings" },
          "configuration": {
            "custom_root_fields": { "select": "meetings" },
            "custom_column_names": {
              "term_code": "termCode",
              "section_id": "sectionId",
              "meeting_index": "meetingIndex",
              "meeting_date": "date",
              "start_time": "startTime",
              "end_time": "endTime",
              "is_tba": "isTba",
              "meeting_type": "meetingType",
              "raw_days": "rawDays",
              "raw_time": "rawTime",
              "raw_location": "rawLocation"
            }
          },
          "select_permissions": [
            {
              "role": "anonymous",
              "permission": {
                "columns": [
                  "term_code",
                  "section_id",
                  "meeting_index",
                  "days",
                  "meeting_date",
                  "start_time",
                  "end_time",
                  "building",
                  "room",
                  "is_tba",
                  "meeting_type",
                  "raw_days",
                  "raw_time",
                  "raw_location"
                ],
                "filter": {},
                "limit": 2000
              }
            }
          ]
        },
        {
          "table": { "schema": "public", "name": "instructors" },
          "configuration": {
            "custom_root_fields": { "select": "instructors" },
            "custom_column_names": {
              "instructor_name": "instructorName"
            }
          },
          "select_permissions": [
            {
              "role": "anonymous",
              "permission": {
                "columns": ["instructor_name"],
                "filter": {},
                "limit": 1000
              }
            }
          ]
        },
        {
          "table": {
            "schema": "public",
            "name": "section_instructors"
          },
          "configuration": {
            "custom_root_fields": { "select": "sectionInstructors" },
            "custom_column_names": {
              "term_code": "termCode",
              "section_id": "sectionId",
              "instructor_name": "instructorName"
            }
          },
          "object_relationships": [
            {
              "name": "instructor",
              "using": {
                "foreign_key_constraint_on": "instructor_name"
              }
            }
          ],
          "select_permissions": [
            {
              "role": "anonymous",
              "permission": {
                "columns": ["term_code", "section_id", "instructor_name"],
                "filter": {},
                "limit": 2000
              }
            }
          ]
        }
      ]
    }
  ]
}
