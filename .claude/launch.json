{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "bun",
      "runtimeArgs": [
        "run",
        "--cwd",
        "frontend",
        "start",
        "--",
        "--host",
        "127.0.0.1",
        "--port",
        "3001"
      ],
      "port": 3001
    },
    {
      "name": "frontend-test",
      "runtimeExecutable": "env",
      "runtimeArgs": [
        "VITE_API_ENDPOINT=",
        "VITE_PUBLIC_LOGIN_ENABLED=false",
        "bun",
        "run",
        "--cwd",
        "frontend",
        "start",
        "--mode",
        "test",
        "--host",
        "127.0.0.1",
        "--port",
        "3002",
        "--strictPort"
      ],
      "port": 3002
    }
  ]
}
